  "item": [
    {
      "name": "GET - Step 1 SWAPI Single Person",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const jsonData = pm.response.json();\r",
              "pm.environment.set(\"personId\", pm.iterationData.get(\"personId\"));\r",
              "\r",
              "\r",
              "// Status Code\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// name equals personName from CSV\r",
              "pm.test(\"Name matches CSV\", function () {\r",
              "    pm.expect(jsonData.name).to.eql(\r",
              "        pm.iterationData.get(\"personName\")\r",
              "    );\r",
              "});\r",
              "\r",
              "// films length equals filmCount from CSV\r",
              "pm.test(\"Film count matches CSV\", function () {\r",
              "    pm.expect(jsonData.films.length).to.eql(\r",
              "        parseInt(pm.iterationData.get(\"filmCount\"))\r",
              "    );\r",
              "});\r",
              "\r",
              "// height is returned as string\r",
              "pm.test(\"Height is a string\", function () {\r",
              "    pm.expect(jsonData.height).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "//  homeworld contains homeworldId from CSV\r",
              "pm.test(\"Homeworld contains expected homeworldId\", function () {\r",
              "    pm.expect(jsonData.homeworld).to.include(\r",
              "        pm.iterationData.get(\"homeworldId\")\r",
              "    );\r",
              "});\r",
              "\r",
              "// adding in env veribale URL for Request 2\r",
              "pm.environment.set(\"homeworldUrl\", jsonData.homeworld);\r",
              "\r",
              "// adding in env veribale URL  URL for Request 3\r",
              "pm.environment.set(\"firstFilmUrl\", jsonData.films[0]);\r",
              "\r",
              "// Optional logging\r",
              "console.log(\"homeworldUrl =\", jsonData.homeworld);\r",
              "console.log(\"firstFilmUrl =\", jsonData.films[0]);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{swapiBase}}/people/{{personId}}/",
          "host": [
            "{{swapiBase}}"
          ],
          "path": [
            "people",
            "{{personId}}",
            ""
          ]
        }
      },
      "response": []
    },
    {
