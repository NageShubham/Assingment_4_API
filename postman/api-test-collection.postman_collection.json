    {
      "name": "GET - Step5 - AIC Pagination Validation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Data is an array of length 10\", function () {\r",
              "    pm.expect(jsonData.data).to.be.an(\"array\");\r",
              "    pm.expect(jsonData.data.length).to.eql(10);\r",
              "});\r",
              "\r",
              "pm.test(\"pagination.total is greater than 100000\", function () {\r",
              "    pm.expect(jsonData.pagination.total).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.pagination.total).to.be.greaterThan(100000);\r",
              "});\r",
              "\r",
              "pm.test(\"pagination.current_page equals 1\", function () {\r",
              "    pm.expect(jsonData.pagination.current_page).to.eql(1);\r",
              "});\r",
              "\r",
              "pm.test(\"pagination.total_pages is greater than current_page\", function () {\r",
              "    pm.expect(jsonData.pagination.total_pages).to.be.a(\"number\");\r",
              "    pm.expect(jsonData.pagination.total_pages)\r",
              "        .to.be.greaterThan(jsonData.pagination.current_page);\r",
              "});\r",
              "\r",
              "pm.test(\"Every item has numeric id and string title\", function () {\r",
              "    jsonData.data.forEach(item => {\r",
              "        pm.expect(item.id).to.be.a(\"number\");\r",
              "        pm.expect(item.title).to.be.a(\"string\");\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{aicBase}}/artworks?page=1&limit=10&fields=id,title,artist_display",
          "host": [
            "{{aicBase}}"
          ],
          "path": [
            "artworks"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "fields",
              "value": "id,title,artist_display"
            }
          ]
        }
      },
      "response": []
