              "    pm.expect(jsonData.name.trim().length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"population is a string\", function () {\r",
              "    pm.expect(jsonData.population).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"climate is a non-empty string\", function () {\r",
              "    pm.expect(jsonData.climate).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.climate.trim().length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"terrain is a non-empty string\", function () {\r",
              "    pm.expect(jsonData.terrain).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.terrain.trim().length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// Capture climate for later requests\r",
              "pm.environment.set(\"homeworldClimate\", jsonData.climate);"
