    {
      "name": "GET - Stpe4 - AIC Artwork Lookup",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "const artworksData = jsonData.data;\r",
              "\r",
              "pm.test(\"artworksData.id equals artworkId from CSV\", function () {\r",
              "    pm.expect(artworksData.id).to.eql(parseInt(pm.iterationData.get(\"artworkId\")));\r",
              "});\r",
              "\r",
              "pm.test(\"artist_display contains expectedArtist\", function () {\r",
              "    pm.expect(artworksData.artist_display).to.include(\r",
              "        pm.iterationData.get(\"expectedArtist\")\r",
              "    );\r",
              "});\r",
              "\r",
              "pm.test(\"title is a non-empty string\", function () {\r",
              "    pm.expect(artworksData.title).to.be.a(\"string\").and.not.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"medium_display key exists\", function () {\r",
              "    pm.expect(artworksData).to.have.property(\"medium_display\");\r",
              "});\r",
              "\r",
              "pm.environment.set('artworkId',data.id);\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
